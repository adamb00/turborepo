{
  "name": "turborepo_3",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "bootstrap": "bash scripts/bootstrap.sh",
    "db:down": "docker compose --env-file .env.development -f docker-compose.dev.yaml down",
    "db:logs": "docker compose --env-file .env.development -f docker-compose.dev.yaml logs -f db",
    "db:migrate:deploy": "turbo run db:migrate:deploy",
    "db:migrate:dev": "pnpm --filter @workspace/database exec prisma migrate dev",
    "db:migrate:dev:up": "pnpm run db:up && pnpm run db:migrate:dev",
    "db:migrate:dev:up:named": "pnpm run db:up && pnpm --filter @workspace/database exec prisma migrate dev --name ${MIGRATION_NAME:-manual_migration}",
    "db:push": "turbo run db:push",
    "db:reset": "docker compose --env-file .env.development -f docker-compose.dev.yaml down -v db redis",
    "db:seed": "turbo run db:seed",
    "db:studio": "pnpm run db:up && pnpm --filter @workspace/database studio -- --port 5555 --browser chrome",
    "db:up": "docker compose --env-file .env.development -f docker-compose.dev.yaml up -d db redis maildev",
    "dev": "turbo run dev",
    "dev:setup": "bash scripts/dev-setup.sh",
    "dev:with-db": "bash scripts/dev-with-db.sh",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "generate": "turbo run generate",
    "lint": "turbo run lint",
    "setup": "bash scripts/template-setup.sh",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run build"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.6",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "msw",
      "sharp",
      "unrs-resolver"
    ],
    "peerDependencyRules": {
      "allowAny": [
        "postcss",
        "nodemailer",
        "chokidar"
      ]
    }
  }
}
